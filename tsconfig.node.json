{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "electron.vite.config.*",
    "electron/**/*",
    "src/main/**/*",
    "src/preload/**/*"
  ],
  "compilerOptions": {
    "ignoreDeprecations": "5.0",
    "composite": true,
    "noEmit": false,
    "outDir": "./out/types",
    "baseUrl": ".",
    "types": ["node", "electron-vite/node"],
    "paths": {
      "@/*": ["src/*"]
    }
  }
}
